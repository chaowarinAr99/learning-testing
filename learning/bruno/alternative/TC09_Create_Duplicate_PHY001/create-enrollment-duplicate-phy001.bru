meta {
  name: Create Enrollment - duplicate PHY001
  type: http
  seq: 15
}

post {
  url: http://localhost:3000/enrollments
  body: json
  auth: none
}

headers {
  content-type: application/json
}

body:json {
  {
    "employeeId": "EMP009",
    "courseId": "PHY001"
  }
}

tests {
  test("status code is 409", function() {
    expect(res.getStatus()).to.equal(409);
  });

  test("response body is correct", function() {
    const body = res.getBody();
    expect(body.message).to.equal("Employee already enrolled");
  });
}
