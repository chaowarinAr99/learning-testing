meta {
  name: Create Enrollment - course not found
  type: http
  seq: 12
}

post {
  url: http://localhost:3000/enrollments
  body: json
  auth: none
}

headers {
  content-type: application/json
}

body:json {
  {
    "employeeId": "EMP006",
    "courseId": "BIG001"
  }
}

tests {
  test("status code is 404", function() {
    expect(res.getStatus()).to.equal(404);
  });

  test("response body is correct", function() {
    const body = res.getBody();
    expect(body.message).to.equal("Course not found");
  });
}
