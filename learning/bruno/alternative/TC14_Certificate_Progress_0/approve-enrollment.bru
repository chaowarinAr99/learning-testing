meta {
  name: Approve Enrollment TC14
  type: http
  seq: 1102
}

patch {
  url: http://localhost:3000/enrollments/{{enrollmentId14}}/approve
  body: json
  auth: none
}

script:pre-request {
  if (!bru.getVar("enrollmentId14")) {
    throw new Error("Missing enrollmentId14");
  }
}

headers {
  content-type: application/json
}

body:json {
  {
    "approvedBy": "HR014"
  }
}

tests {
  test("status code is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
}
